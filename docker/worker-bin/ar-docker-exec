#!/usr/bin/env bash
set -euo pipefail
SERVICE="${1:-}"
shift || true
COMMAND="$(python3 -c 'import json,sys; print(json.dumps(sys.argv[1:]))' "$@")"
PAYLOAD="$(python3 -c 'import json,sys; print(json.dumps({"service": sys.argv[1], "command": json.loads(sys.argv[2])}))' "$SERVICE" "$COMMAND")"
ar-broker-request "/broker/jobs/${AGENT_RUNNER_JOB_ID}/docker/compose-exec" "$PAYLOAD"
